{
  "name": "kidhrcode",
  "version": "1.0.0",
  "main": "index.js",
  "dependencies": {
    "@expo/metro-runtime": "~57.0.2",
    "@monaco-editor/react": "^4.7.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.110.0",
    "@types/react": "~19.2.4",
    "expo": "~57.0.1",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.2",
    "expo-linking": "~57.0.1",
    "expo-router": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "monaco-editor": "^0.55.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "typescript": "~6.0.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.5"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "electron": "electron electron/main.js",
    "electron:dev": "concurrently \"expo start --web\" \"wait-on http://localhost:8081 && electron electron/main.js\"",
    "electron:build": "electron-builder --win --mac --linux",
    "electron:build:win": "electron-builder --win",
    "electron:build:mac": "electron-builder --mac",
    "electron:build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.kidhrcode.app",
    "productName": "KidhrCode",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      "desktop/ui/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/icon-512.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icons/icon-512.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "shortcutName": "KidhrCode"
    }
  },
  "private": true
}
