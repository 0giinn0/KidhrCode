{
  "expo": {
    "name": "KidhrCode",
    "slug": "kidhrcode",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "kidhrcode",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kidhrcode.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.kidhrcode.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "language": "en-US",
      "description": "Learn every programming language for free",
      "shortName": "KidhrCode"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar"
    ]
  }
}
